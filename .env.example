# Public Supabase (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase (service role, bypasses RLS — NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs for platform merchant subscription plans (optional; seeded if missing)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ShopStack <noreply@example.com>

# Public URL of the deployed app (used in Stripe return URLs, emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
