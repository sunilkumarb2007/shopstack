# Public Supabase (exposed to browser).
# Supabase renamed `anon key` → `publishable key` in late 2024; either var name works.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key  # legacy name, still supported

# Server-only Supabase (bypasses RLS — NEVER expose to the client).
# Supabase renamed `service_role key` → `secret key` in late 2024; either var name works.
SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # legacy name, still supported

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs for platform merchant subscription plans (optional; seeded if missing)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ShopStack <noreply@example.com>

# Public URL of the deployed app (used in Stripe return URLs, emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
